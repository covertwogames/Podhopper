<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- PodHopper: car (Android Automotive) sign-in and pairing. Shown only on the car. -->

    <!-- Media browser sign-in prompt (shown in the car's media UI when not signed in) -->
    <string name="podhopper_car_signin_button">Sign In</string>
    <string name="podhopper_car_signin_message">Sign in to see your podcasts here. While parked, tap Sign In to connect this car to PodHopper on your phone.</string>

    <!-- Pairing screen -->
    <string name="podhopper_car_pairing_title">Sign in to PodHopper</string>
    <string name="podhopper_car_pairing_instructions">On your phone:\n\n1. Open PodHopper\n2. Go to Settings, then Sync Account to Car App\n3. Enter the code below</string>
    <string name="podhopper_car_pairing_code_label">Your code</string>
    <string name="podhopper_car_pairing_waiting">Waiting for your phone...</string>
    <string name="podhopper_car_pairing_success">You are signed in. Loading your podcasts...</string>
    <string name="podhopper_car_pairing_expired">That code expired. Get a new one to try again.</string>
    <string name="podhopper_car_pairing_error">Could not reach PodHopper. Check the car\'s connection and try again.</string>
    <string name="podhopper_car_pairing_retry">Get a new code</string>

    <!-- Email fallback -->
    <string name="podhopper_car_pairing_email_prompt">Prefer to sign in directly?</string>
    <string name="podhopper_car_pairing_email_button">Sign in with email</string>
    <string name="podhopper_car_email_title">Sign in with email</string>
    <string name="podhopper_car_email_address_hint">Email</string>
    <string name="podhopper_car_email_password_hint">Password</string>
    <string name="podhopper_car_email_submit">Sign In</string>
    <string name="podhopper_car_email_error">Sign in failed. Check your email and password, then try again.</string>
    <string name="podhopper_car_email_back">Use a pairing code instead</string>

    <!-- Car settings account row -->
    <string name="podhopper_car_account_signed_in">Signed in as %1$s</string>
    <string name="podhopper_car_account_signed_out">Not signed in</string>
    <string name="podhopper_car_account_sign_in">Sign In</string>
    <string name="podhopper_car_account_sign_out">Sign Out</string>

</resources>
